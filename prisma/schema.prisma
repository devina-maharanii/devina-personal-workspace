datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum DomainStatus {
  PENDING
  VERIFIED
  ERROR
}

enum WebhookDeliveryStatus {
  SUCCESS
  FAILED
  PENDING
}

enum AnnouncementType {
  INFO
  WARNING
  MAINTENANCE
}

enum EmailStatus {
  SENT
  FAILED
}

enum MessageRole {
  user
  assistant
  system
}

model User {
  id                     String             @id @default(uuid())
  clerkId                String             @unique
  email                  String             @unique
  name                   String?
  avatarUrl              String?
  role                   UserRole           @default(USER)
  stripeCustomerId       String?            @unique
  stripeSubscriptionId   String?            @unique
  stripePriceId          String?
  subscriptionStatus     SubscriptionStatus @default(FREE)
  currentPeriodEnd       DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  deletedAt              DateTime?
  needsStripeCustomer    Boolean            @default(true)
  bio                    String?
  timezone               String?
  inAppNotifications     Boolean            @default(true)
  emailNotificationTypes Json               @default("[]")
  notificationDigestFreq String             @default("immediate")

  memberships    Membership[]
  notifications  Notification[]
  aiUsageLogs    AiUsageLog[]
  files          File[]
  apiKeys        ApiKey[]
  auditLogs      AuditLog[]
  invitations    Invitation[]    @relation("InvitedByUser")
  blogPosts      BlogPost[]
  announcements  Announcement[]
  conversations  Conversation[]
  contentReports ContentReport[]

  @@index([stripeCustomerId])
  @@index([subscriptionStatus])
}

model Organization {
  id                   String   @id @default(uuid())
  name                 String
  slug                 String   @unique
  logo                 String?
  plan                 String   @default("FREE")
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  maxMembers           Int      @default(5)
  maxAiCredits         Int      @default(100)
  usedAiCredits        Int      @default(0)
  onboardingCompleted  Boolean  @default(false)
  onboardingStep       Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  members          Membership[]
  invitations      Invitation[]
  blogPosts        BlogPost[]
  settings         OrganizationSettings?
  webhookEndpoints WebhookEndpoint[]
  aiUsageLogs      AiUsageLog[]
  files            File[]
  apiKeys          ApiKey[]
  conversations    Conversation[]

  @@index([stripeCustomerId])
}

model Membership {
  id             String         @id @default(uuid())
  userId         String
  organizationId String
  role           MembershipRole @default(MEMBER)
  joinedAt       DateTime       @default(now())
  createdAt      DateTime       @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@index([organizationId, role])
}

model Invitation {
  id             String         @id @default(uuid())
  email          String
  organizationId String
  role           MembershipRole @default(MEMBER)
  token          String         @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime       @default(now())
  invitedById    String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitedByUser", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([invitedById])
}

model BlogPost {
  id             String    @id @default(uuid())
  title          String
  slug           String    @unique
  content        String
  excerpt        String?
  coverImage     String?
  published      Boolean   @default(false)
  publishedAt    DateTime?
  authorId       String
  organizationId String
  seoTitle       String?
  seoDescription String?
  tags           String[]
  reportCount    Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  author         User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  versions       BlogPostVersion[]
  contentReports ContentReport[]

  @@index([authorId])
  @@index([organizationId])
  @@index([tags], type: Gin)
}

model ContentReport {
  id         String   @id @default(uuid())
  postId     String
  reason     String
  reporterId String
  createdAt  DateTime @default(now())

  post     BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([reporterId])
}

model BlogPostVersion {
  id         String   @id @default(uuid())
  postId     String
  content    String
  title      String
  excerpt    String?
  coverImage String?
  createdAt  DateTime @default(now())

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  read      Boolean          @default(false)
  readAt    DateTime?
  link      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt, read])
}

model AiUsageLog {
  id               String   @id @default(uuid())
  userId           String
  organizationId   String
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  cost             Float
  feature          String
  createdAt        DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
}

model File {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  name           String
  url            String
  key            String
  size           Int
  mimeType       String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
}

model WebhookEvent {
  id            String   @id @default(uuid())
  type          String
  stripeEventId String   @unique
  processed     Boolean  @default(false)
  data          Json
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

model OrganizationSettings {
  id                      String        @id @default(uuid())
  organizationId          String        @unique
  customDomain            String?       @unique
  domainVerificationToken String?
  domainStatus            DomainStatus?
  domainVerifiedAt        DateTime?
  brandColor              String?
  customFooterText        String?
  features                Json          @default("{}")
  emailNotifications      Boolean       @default(true)
  emailNotificationTypes  Json          @default("[]")
  notificationDigestFreq  String        @default("immediate")
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([customDomain])
}

model ApiKey {
  id         String    @id @default(uuid())
  userId     String
  orgId      String
  name       String
  keyHash    String
  keyPrefix  String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orgId])
  @@index([keyPrefix])
}

model WebhookEndpoint {
  id        String   @id @default(uuid())
  orgId     String
  url       String
  secret    String
  events    String[]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deliveries   WebhookDelivery[]

  @@index([orgId])
}

model WebhookDelivery {
  id         String                @id @default(uuid())
  endpointId String
  event      String
  payload    Json
  response   Json?
  status     WebhookDeliveryStatus @default(PENDING)
  attempts   Int                   @default(1)
  createdAt  DateTime              @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Announcement {
  id          String           @id @default(uuid())
  title       String
  message     String
  type        AnnouncementType @default(INFO)
  active      Boolean          @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdById String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
}

model EmailLog {
  id        String      @id @default(uuid())
  to        String
  subject   String
  template  String
  status    EmailStatus
  error     String?
  sentAt    DateTime    @default(now())
  createdAt DateTime    @default(now())
}

model Conversation {
  id             String   @id @default(uuid())
  title          String
  userId         String
  organizationId String
  model          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@index([userId])
  @@index([organizationId])
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  role           MessageRole
  content        String
  fileUrl        String?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}
