# ─── APP CONFIGURATION ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="AI SaaS Boilerplate Pro"
NODE_ENV="development" # development, production, or test

# ─── DATABASE CONFIGURATION (Prisma ORM) ──────────────────────────────────────
# PostgreSQL connection string for Prisma. Typically points to a pooler in production (e.g. pgBouncer, Supabase).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_saas_boilerplate?schema=public"
# Direct connection string to PostgreSQL (bypass pooling) — essential for running migrations.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/ai_saas_boilerplate?schema=public"

# ─── CLERK AUTHENTICATION (https://clerk.com) ─────────────────────────────────
# Client Publishable Key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
# Server Secret Key (keep this highly confidential)
CLERK_SECRET_KEY="sk_test_..."
# Clerk webhook signature verification secret for user synchronization
CLERK_WEBHOOK_SECRET="whsec_..."
# Route Paths for custom auth flows
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# ─── STRIPE PAYMENTS (https://stripe.com) ─────────────────────────────────────
# Client Publishable Key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Server Secret Key (keep this highly confidential)
STRIPE_SECRET_KEY="sk_test_..."
# Stripe webhook signing secret to verify incoming webhooks safely
STRIPE_WEBHOOK_SECRET="whsec_..."
# Pricing Tier ID plans (Stripe Dashboard -> Products -> Price ID)
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_ENTERPRISE_PRICE_ID="price_..."
# Annual pricing tier IDs (optional — used for annual billing plans)
STRIPE_PRO_ANNUAL_PRICE_ID="price_..."
STRIPE_ENTERPRISE_ANNUAL_PRICE_ID="price_..."

# ─── RESEND EMAIL (https://resend.com) ────────────────────────────────────────
# Resend API Key for dispatching transaction emails
RESEND_API_KEY="re_..."
# The from email address (must be configured on a verified domain in Resend)
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# ─── UPLOADTHING FILE UPLOADS (https://uploadthing.com) ──────────────────────
# Secret Key
UPLOADTHING_SECRET="sk_live_..."
# UploadThing Application Identifier
NEXT_PUBLIC_UPLOADTHING_APP_ID="..."

# ─── AI SERVICES (Google Gemini & Anthropic) ──────────────────────────────────
# Google Gemini API key (Primary content model)
GEMINI_API_KEY="AIzaSy..."
# Anthropic API Key (Secondary model support)
ANTHROPIC_API_KEY="sk-ant-..."

# ─── UPSTASH REDIS & RATE LIMITING (https://upstash.com) ──────────────────────
# Redis REST connection URL
UPSTASH_REDIS_REST_URL="https://...-redis.upstash.io"
# Redis connection token
UPSTASH_REDIS_REST_TOKEN="..."

# ─── SENTRY MONITORING (https://sentry.io) ────────────────────────────────────
# Sentry DSN endpoint (Server & Edge context)
SENTRY_DSN="https://..."
# Sentry DSN endpoint (Client context)
NEXT_PUBLIC_SENTRY_DSN="https://..."
# Sentry Authentication Token (used during build to upload source maps)
SENTRY_AUTH_TOKEN="sntryu_..."
# Sentry Organization Slug
SENTRY_ORG="..."
# Sentry Project Slug
SENTRY_PROJECT="..."

# ─── POSTHOG ANALYTICS (https://posthog.com) ──────────────────────────────────
# Client PostHog API Key
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
# Client PostHog Ingestion URL Host
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
# Server-side PostHog API Key
POSTHOG_API_KEY="phx_..."

# ─── CRON WORKFLOW PROTECTION ─────────────────────────────────────────────────
# Custom security secret passed in Authorization headers to secure cron endpoints
CRON_SECRET="your-random-secret-here"

# ─── SYSTEM GENERAL SECURED WEBHOOKS ──────────────────────────────────────────
# Secret key used for authenticating outgoing system webhooks
WEBHOOK_SECRET="whsec_..."
